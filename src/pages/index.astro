---
// 1. ИМПОРТИРУЕМ НОВЫЕ МЕТОДЫ
import { getCollection, render } from 'astro:content';

// 2. ЗАБИРАЕМ ЗАМЕТКИ ИЗ КОЛЛЕКЦИИ 'blog'
// Фильтруем: оставляем только те, где publish: true
const allPosts = await getCollection('blog', ({ data }) => {
  return data.publish === true;
});

// 3. СОРТИРУЕМ (новые сверху)
const posts = allPosts.sort((a, b) => new Date(b.data.created).valueOf() - new Date(a.data.created).valueOf());
---

<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>dalekodolgo - микроблог</title>
  
  <!-- Подключаем стили карты Leaflet -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <!-- Подключаем стили Lightbox для картинок -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css" />
  <!-- ПОДКЛЮЧАЕМ ШРИФТ INTER -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

  <style is:global>
  /* Базовые стили страницы */
  body {
    margin: 0;
    padding: 0;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    display: flex;
    flex-direction: row;
    height: 100vh;
    background-color: #f5f5f7;
    overflow: hidden;
  }

  #map {
    width: 60%;
    height: 100vh;
    z-index: 1;
    flex-shrink: 0;
  }

  #feed {
    width: 40%;
    height: 100vh;
    overflow-y: auto;
    padding: 6px; /* Убрали воздух почти в ноль */
    display: flex;
    flex-direction: column;
    gap: 8px; /* Чуть добавили расстояния, чтобы бордер не слипался */
    box-sizing: border-box;
  }

  .post-card {
    background: white;
    padding: 12px;
    border: 1px solid #e5e5e5; /* Тонкий бордер для разделения */
    border-radius: 0 !important; /* Убрали скругления */
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    box-shadow: none; /* Убрали тень, заменяем бордером */
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .post-card:hover {
    border-color: #cfcfcf; /* Бордер темнеет при наведении */
    box-shadow: 0 2px 8px rgba(0,0,0,0.04); /* Легкая тень при ховере */
    transform: translateY(-1px);
  }

  .post-content {
    flex: 1;
    overflow: hidden;
    padding-right: 8px;
  }

  .post-meta {
    font-size: 12px;
    color: #8e8e93;
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* Плашка километра (совпадает с цветом трека) */
  .km-badge {
    background: #ffd900; /* Цвет линии трека */
    color: #111111; /* Темный текст для читаемости на желтом */
    padding: 3px 8px;
    border-radius: 0 !important; /* Убрали скругления */
    font-size: 11px;
    font-weight: 600;
    line-height: 1;
  }

  .post-text {
    font-size: 14px;
    line-height: 1.5;
    color: #111111;
  }

  /* Превью картинок (100x100) */
  .post-text img {
    width: 100px; /* Было 120px */
    height: 100px; /* Было 120px */
    object-fit: cover;
    float: right;
    margin-left: 10px;
    margin-bottom: 2px;
    border-radius: 0 !important; /* Убрали скругления */
    cursor: pointer;
    transition: transform 0.2s ease;
  }

  .post-text img:hover {
    transform: scale(1.03);
  }

  /* Скрываем стрелки в Lightbox, чтобы нельзя было листать */
  .glightbox-container .gnext,
  .glightbox-container .gprev {
    display: none !important;
  }

  /* Мобильная адаптация */
  @media (max-width: 768px) {
    body {
      flex-direction: column;
    }
    #map {
      width: 100%;
      height: 50vh;
    }
    #feed {
      width: 100%;
      height: 50vh;
    }
  }
</style>
</head>
<body>

  <div id="map"></div>

  <div id="feed">
    {posts.map(async (post) => {
      // Форматируем дату для красивого вывода
      const date = new Date(post.data.created);
      const timeStr = date.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' });
      const dateStr = date.toLocaleDateString('ru-RU', { day: 'numeric', month: 'short' });

      // Рендерим текст заметки из Markdown в HTML
      const { Content } = await render(post);

      return (
        <div class="post-card" data-km={post.data.km}>
          <div class="post-content">
            <div class="post-meta">
              <span>{dateStr}, {timeStr}</span>
              {post.data.km && <span class="km-badge">КМ: {post.data.km}</span>}
            </div>
            <div class="post-text"><Content /></div>
          </div>
          <div class="post-thumb"></div>
        </div>
      );
    })}
  </div>
  
  <!-- Подключаем Lightbox для картинок -->
  <script is:inline src="https://cdn.jsdelivr.net/gh/mcstudios/glightbox/dist/js/glightbox.min.js"></script>

  <!-- СКРИПТЫ КАРТЫ -->
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/leaflet-gpx/1.7.0/gpx.min.js"></script>
  
  <script is:inline>
    const map = L.map('map').setView([55.75, 37.61], 10);
    let initialBounds = null;
    let initialZoom = null;

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
    }).addTo(map);

    const markers = {};

    // 1. ВИЗУАЛЬНАЯ ОТРИСОВКА ТРЕКА
    new L.GPX('/route.gpx', {
      async: true,
      polyline_options: {
        color: '#ffd900', // Цвет линии трека
        weight: 4,        // Толщина
        opacity: 0.8      // Прозрачность
      },
      marker_options: {
        startIconUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet-gpx/1.7.0/pin-icon-start.png',
        endIconUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet-gpx/1.7.0/pin-icon-end.png', 
        shadowUrl: 'https://cdnjs.cloudflare.com/ajax/libs/leaflet-gpx/1.7.0/pin-shadow.png'
      }
    }).on('loaded', function(e) {
      map.fitBounds(e.target.getBounds());
      initialBounds = e.target.getBounds();
      initialZoom = map.getZoom();
    }).addTo(map);

    // 2. БРОНЕБОЙНОЕ ЧТЕНИЕ ТОЧЕК
    fetch('/route.gpx')
      .then(response => response.text())
      .then(gpxText => {
        const parser = new DOMParser();
        const xmlDoc = parser.parseFromString(gpxText, "text/xml");
        const trkpts = xmlDoc.querySelectorAll('trkpt');
        
        if (trkpts.length === 0) return;

        let trackPoints = [];
        trkpts.forEach(pt => {
          const lat = parseFloat(pt.getAttribute('lat'));
          const lon = parseFloat(pt.getAttribute('lon'));
          if (!isNaN(lat) && !isNaN(lon)) {
            trackPoints.push(L.latLng(lat, lon));
          }
        });

        // 3. ФУНКЦИЯ ПОИСКА КИЛОМЕТРА
        function getCoordsAtKm(targetKm) {
          if (!targetKm || trackPoints.length === 0) return null;
          let totalDist = 0;
          const targetDistMeters = targetKm * 1000;
          for (let i = 1; i < trackPoints.length; i++) {
            const distBetween = trackPoints[i-1].distanceTo(trackPoints[i]);
            if (totalDist + distBetween >= targetDistMeters) {
              return trackPoints[i];
            }
            totalDist += distBetween;
          }
          return null;
        }

        // 4. РАССТАНОВКА МАРКЕРОВ И ЗУМ ПО КЛИКУ
        const postCards = document.querySelectorAll('.post-card[data-km]');

        postCards.forEach(card => {
          const km = parseFloat(card.getAttribute('data-km'));
          
          if (!isNaN(km)) {
            const coords = getCoordsAtKm(km);
            
            if (coords) {
              const marker = L.circleMarker(coords, {
                pane: 'markerPane', // Маркеры поверх трека
                radius: 5,          // Базовый размер (из Save State)
                fillColor: "#ff00dd",
                color: "#fff",
                weight: 1,
                opacity: 1,
                fillOpacity: 0.8
              }).addTo(map);
              
              markers[km] = marker;

              // Событие КЛИКА
              card.addEventListener('click', () => {
                // Сбрасываем размер ВСЕХ маркеров до 5
                for (let key in markers) {
                  markers[key].setStyle({ radius: 5 });
                }
                // Увеличиваем текущий маркер до 8
                marker.setStyle({ radius: 8 }); 
                
                // Умный зум
                const autoZoom = initialZoom ? initialZoom + 2 : 14;
                const targetZoom = Math.max(map.getZoom(), autoZoom);
                map.flyTo(coords, targetZoom, { duration: 0.5 });
              });
            }
          }
        });
      })
      .catch(err => console.error("Ошибка загрузки GPX:", err));

    // Навешиваем Lightbox на все картинки в ленте
    document.querySelectorAll('.post-text img').forEach(img => {
      const src = img.getAttribute('src');
      if (!src) return; 
      const link = document.createElement('a');
      link.setAttribute('href', src);
      link.className = 'glightbox';
      link.setAttribute('data-glightbox', 'type: image');
      img.parentNode.insertBefore(link, img);
      link.appendChild(img);
    });
      
    // Настройки Lightbox без листания
    const lightbox = GLightbox({
      touchNavigation: false, 
      loop: false,
      zoomable: false
    });
  </script>
</body>
</html>