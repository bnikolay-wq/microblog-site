---
// 1. ИМПОРТИРУЕМ МЕТОДЫ
import { getCollection, render } from 'astro:content';

// 2. ЗАБИРАЕМ ЗАМЕТКИ ИЗ КОЛЛЕКЦИИ 'blog'
const allPosts = await getCollection('blog', ({ data }) => {
  return data.publish === true;
});

// 3. СОРТИРУЕМ (новые сверху)
const posts = allPosts.sort((a, b) => new Date(b.data.created).valueOf() - new Date(a.data.created).valueOf());
---

<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PAMIR 2026 - dalekodolgo - микроблог путешествия</title>
  
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  
  <!-- ПОДКЛЮЧАЕМ ВИДЖЕТ ЛАЙКОВ LYKET -->
  <script src="https://unpkg.com/@lyket/widget@latest/dist/index.js"></script>
</head>

<body>
  <!-- ИНИЦИАЛИЗАЦИЯ LYKET С ТВОИМ КЛЮЧОМ -->
  <script is:inline>
    window.lyketOptions = {
      apiKey: "pt_3c87920e5f05723ef33e7e4bb3e216"
    };
  </script>

  <style is:global>
  body {
    margin: 0;
    padding: 0;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    display: flex;
    flex-direction: row;
    height: 100vh;
    background-color: #f5f5f7;
    overflow: hidden;
  }

  #map {
    width: 60%;
    height: 100vh;
    z-index: 1;
    flex-shrink: 0;
    opacity: 0; 
    transition: opacity 0.5s ease; 
  }

  #resizer {
    width: 6px;
    background: #e5e5e5;
    cursor: col-resize;
    flex-shrink: 0;
    z-index: 5;
    transition: background 0.2s ease;
  }

  #resizer:hover, #resizer.active {
    background: #ff00dd; 
  }

  #feed {
    flex: 1; 
    height: 100vh;
    overflow-y: auto;
    padding: 6px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    box-sizing: border-box;
  }

  .post-card {
    background: white;
    padding: 8px 10px;
    border: 1px solid #e5e5e5;
    border-radius: 0 !important;
    display: flex;
    justify-content: space-between;
    align-items: stretch; 
    box-shadow: none;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.2s ease;
    cursor: pointer;
  }

  .post-card:hover {
    border-color: #cfcfcf;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    transform: translateY(-1px);
  }

  .post-content {
    flex: 1;
    overflow: hidden;
    padding-right: 0;
    display: flex;
    flex-direction: column;
  }

  .post-meta {
    font-size: 12px;
    color: #8e8e93;
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .local-time {
    font-size: 10px;
    color: #b0b0b0;
  }

  .post-text {
    font-size: 14px;
    line-height: 1.4; 
    color: #111111;
    flex: 1; /* Занимает всё доступное место, прижимая лайк книзу */
    display: flex;
    align-items: center;
  }

  .post-text p {
    margin: 0 !important;
    padding: 0 !important;
  }

  .post-text img {
    display: none;
  }

  /* Контейнер для кнопки лайк (левый нижний угол) */
  .like-container {
    margin-top: 4px;
    align-self: flex-start; /* Прижимает строго влево */
  }

  .post-thumb {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-left: 10px;
    flex-shrink: 0;
    justify-content: center; 
  }
  
  .post-thumb:empty {
    display: none;
  }

  .post-thumb img {
    width: 60px;  
    height: 60px; 
    object-fit: cover;
    border-radius: 0 !important;
    cursor: pointer;
    transition: transform 0.2s ease;
  }

  .post-thumb img:hover {
    transform: scale(1.03);
  }

  .glightbox-container .gnext,
  .glightbox-container .gprev {
    display: none !important;
  }

  /* Кастомные маркеры старта и финиша */
  .start-finish-marker {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid white;
    box-shadow: 0 1px 4px rgba(0,0,0,0.4);
  }
  .start-marker { background: #00cc44; } 
  .end-marker { background: #ff3333; }   

  @media (max-width: 768px) {
    body {
      flex-direction: column;
    }
    #map {
      width: 100%;
      height: 50vh;
    }
    #resizer {
      display: none;
    }
    #feed {
      width: 100%;
      height: 50vh;
    }
  }
</style>

  <div id="map"></div>
  <div id="resizer"></div>

  <div id="feed">
    {posts.map(async (post) => {
      const date = new Date(post.data.created);
      const timeStr = date.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit' });
      const dateStr = date.toLocaleDateString('ru-RU', { day: 'numeric', month: 'long' });

      const coords = post.data.coordinates ? JSON.stringify(post.data.coordinates) : null;

      const { Content } = await render(post);

      // Уникальный ID для лайков на основе времени создания
      const likeId = `pamir-${date.getTime()}`;

      return (
        <div class="post-card" data-coords={coords}>
          <div class="post-content">
            <div class="post-meta">
              <span>{dateStr}, {timeStr}</span>
              <span class="local-time">(местное время)</span>
            </div>
            <div class="post-text"><Content /></div>
            
            {/* КНОПКА ЛАЙК ОТ LYKET */}
            <div class="like-container">
              <lyket-like 
                id={likeId} 
                namespace="pamir-fun"
              ></lyket-like>
            </div>

          </div>
          <div class="post-thumb"></div>
        </div>
      );
    })}
  </div>
  
  <script is:inline src="https://cdn.jsdelivr.net/gh/mcstudios/glightbox/dist/js/glightbox.min.js"></script>
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/leaflet-gpx/1.7.0/gpx.min.js"></script>
  
  <script is:inline>
    const map = L.map('map').setView([55.75, 37.61], 10);
    let initialBounds = null;
    let initialZoom = null;

    L.tileLayer('https://mt{s}.google.com/vt/lyrs=p&x={x}&y={y}&z={z}', {
      attribution: '&copy; Google Terrain',
      subdomains: '0123',
      maxZoom: 20
    }).addTo(map);

    const markers = {};

    new L.GPX('/route.gpx', {
      async: true,
      polyline_options: {
        color: '#ffd900',
        weight: 4,        
        opacity: 0.8      
      },
      marker_options: {
        startIconUrl: null, 
        endIconUrl: null,
        shadowUrl: null
      }
    }).on('loaded', function(e) {
      map.fitBounds(e.target.getBounds());
      initialBounds = e.target.getBounds();
      map.setZoom(map.getZoom() - 1); 
      initialZoom = map.getZoom();
      document.getElementById('map').style.opacity = '1';
    }).addTo(map);

    fetch('/route.gpx')
      .then(response => response.text())
      .then(gpxText => {
        const parser = new DOMParser();
        const xmlDoc = parser.parseFromString(gpxText, "text/xml");
        const trkpts = xmlDoc.querySelectorAll('trkpt');
        
        if (trkpts.length === 0) return;

        let trackPoints = [];
        trkpts.forEach(pt => {
          const lat = parseFloat(pt.getAttribute('lat'));
          const lon = parseFloat(pt.getAttribute('lon'));
          if (!isNaN(lat) && !isNaN(lon)) {
            trackPoints.push(L.latLng(lat, lon));
          }
        });

        if (trackPoints.length > 0) {
          const startPoint = trackPoints[0];
          const endPoint = trackPoints[trackPoints.length - 1];

          const startIcon = L.divIcon({
            className: '', 
            html: '<div class="start-finish-marker start-marker"></div>',
            iconSize: [12, 12],
            iconAnchor: [6, 6]
          });
          const endIcon = L.divIcon({
            className: '', 
            html: '<div class="start-finish-marker end-marker"></div>',
            iconSize: [12, 12],
            iconAnchor: [6, 6]
          });

          L.marker(startPoint, { icon: startIcon, pane: 'markerPane' }).addTo(map);
          L.marker(endPoint, { icon: endIcon, pane: 'markerPane' }).addTo(map);
        }
      })
      .catch(err => console.error("Ошибка загрузки GPX:", err));

    const postCards = document.querySelectorAll('.post-card[data-coords]');

    postCards.forEach(card => {
      const coordsStr = card.getAttribute('data-coords');
      if (!coordsStr || coordsStr === 'null') return;

      try {
        const arr = JSON.parse(coordsStr);
        if (Array.isArray(arr) && arr.length >= 2) {
          const lat = parseFloat(arr[0]);
          const lon = parseFloat(arr[1]);

          if (!isNaN(lat) && !isNaN(lon)) {
            const coords = L.latLng(lat, lon);
            
            const marker = L.circleMarker(coords, {
              pane: 'markerPane', 
              radius: 5,          
              fillColor: "#ff00dd",
              color: "#fff",
              weight: 1,
              opacity: 1,
              fillOpacity: 0.8
            }).addTo(map);
            
            const key = `${lat},${lon}`;
            markers[key] = marker;

            card.addEventListener('click', () => {
              for (let key in markers) {
                markers[key].setStyle({ radius: 5 });
              }
              marker.setStyle({ radius: 8 }); 
              
              const autoZoom = initialZoom ? initialZoom + 2 : 14;
              const targetZoom = Math.max(map.getZoom(), autoZoom);
              map.flyTo(coords, targetZoom, { duration: 0.5 });
            });

            marker.on('click', () => {
              for (let key in markers) {
                markers[key].setStyle({ radius: 5 });
              }
              marker.setStyle({ radius: 8 });

              card.scrollIntoView({ behavior: 'smooth', block: 'center' });

              card.style.borderColor = 'rgba(255, 0, 221, 0.5)';
              card.style.boxShadow = '0 0 8px rgba(255, 0, 221, 0.3)';
              
              setTimeout(() => {
                card.style.borderColor = '#e5e5e5';
                card.style.boxShadow = 'none';
              }, 1500);
            });
          }
        }
      } catch(e) {
        console.error("Ошибка парсинга координат", e);
      }
    });

    document.querySelectorAll('.post-card').forEach(card => {
      const images = card.querySelectorAll('.post-text img');
      const thumb = card.querySelector('.post-thumb');
      
      if (images.length > 0 && thumb) {
        images.forEach(img => {
          img.style.display = 'block';
          const src = img.getAttribute('src');
          if (src) {
            const link = document.createElement('a');
            link.setAttribute('href', src);
            link.className = 'glightbox';
            link.setAttribute('data-glightbox', 'type: image');
            img.parentNode.insertBefore(link, img);
            link.appendChild(img);
            thumb.appendChild(link);
          }
        });
      }
    });
      
    const lightbox = GLightbox({
      touchNavigation: false, 
      loop: false,
      zoomable: false
    });

    const resizer = document.getElementById('resizer');
    const mapEl = document.getElementById('map');
    let isResizing = false;

    resizer.addEventListener('mousedown', (e) => {
      isResizing = true;
      resizer.classList.add('active');
      document.body.style.userSelect = 'none';
    });

    document.addEventListener('mousemove', (e) => {
      if (!isResizing) return;
      const windowWidth = window.innerWidth;
      let newWidth = (e.clientX / windowWidth) * 100;
      if (newWidth < 15) newWidth = 15;
      if (newWidth > 85) newWidth = 85;
      mapEl.style.width = newWidth + '%';
      map.invalidateSize();
    });

    document.addEventListener('mouseup', () => {
      if (isResizing) {
        isResizing = false;
        resizer.classList.remove('active');
        document.body.style.userSelect = '';
      }
    });
  </script>
</body>
</html>